{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Breg Debug: Interactive Console",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/breg/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/breg:${env:PYTHONPATH}"
            },
            "args": ["-d", "${workspaceFolder}/classified/tmp_proj/", "-i"]
        }
    ]
}
